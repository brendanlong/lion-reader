# Environment variables for integration tests
# This uses a separate database to avoid wiping dev data during test runs

DATABASE_URL=postgresql://lionreader:lionreader@localhost:5432/lionreader_test
REDIS_URL=redis://localhost:6379
NODE_ENV=test

# Allow tests to fetch from localhost/private addresses (SSRF protection is off in tests)
ALLOW_PRIVATE_NETWORK_FETCH=true
