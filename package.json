{
  "name": "lion-reader",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "postinstall": "node scripts/copy-onnx-wasm.mjs",
    "dev": "concurrently --kill-others --names worker,next,discord \"pnpm dev:worker\" \"pnpm dev:next\" \"pnpm dev:discord-bot\"",
    "dev:next": "tsx scripts/server.ts",
    "dev:worker": "tsx watch --clear-screen=false scripts/worker.ts",
    "dev:discord-bot": "tsx watch --clear-screen=false scripts/discord-bot.ts",
    "build": "next build --webpack",
    "build:worker": "node scripts/build-worker.mjs",
    "build:worker-thread": "node scripts/build-worker-thread.mjs",
    "build:discord-bot": "node scripts/build-discord-bot.mjs",
    "build:migrate": "node scripts/build-migrate.mjs",
    "build:all": "pnpm build && pnpm build:server && pnpm build:worker && pnpm build:worker-thread && pnpm build:discord-bot && pnpm build:migrate",
    "build:server": "node scripts/build-server.mjs",
    "start": "node dist/server.js",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "knip": "knip --include files,dependencies,devDependencies,exports",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "db:migrate": "dotenv -- tsx scripts/migrate.ts",
    "db:schema": "dotenv -- tsx scripts/dump-schema.ts",
    "db:seed": "dotenv -- tsx scripts/seed.ts",
    "db:migrate:test": "dotenv -o -e .env.test -- tsx scripts/migrate.ts",
    "db:schema:test": "dotenv -o -e .env.test -- tsx scripts/dump-schema.ts",
    "test": "pnpm db:migrate:test && pnpm db:schema:test && dotenv -o -e .env.test -- vitest",
    "test:unit": "dotenv -o -e .env.test -- vitest run tests/unit",
    "test:integration": "pnpm db:migrate:test && pnpm db:schema:test && dotenv -o -e .env.test -- vitest run tests/integration",
    "test:e2e": "pnpm db:migrate:test && dotenv -o -e .env.test -- playwright test",
    "worker": "tsx scripts/worker.ts",
    "mcp:serve": "dotenv -- tsx src/server/mcp/bin.ts",
    "discord-bot": "dotenv -- tsx scripts/discord-bot.ts"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix --max-warnings 0 --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,css,scss,yaml,yml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@mintplex-labs/piper-tts-web": "^1.0.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "@sentry/nextjs": "^10.48.0",
    "@tanstack/react-query": "^5.101.0",
    "@trpc/client": "^11.10.0",
    "@trpc/react-query": "^11.10.0",
    "@trpc/server": "^11.10.0",
    "arctic": "^3.7.0",
    "argon2": "^0.44.0",
    "aws4fetch": "^1.0.20",
    "concurrently": "^10.0.3",
    "discord.js": "^14.26.2",
    "drizzle-orm": "^0.45.2",
    "fast-xml-parser": "^5.8.0",
    "google-auth-library": "^10.6.2",
    "groq-sdk": "^1.2.1",
    "html-entities": "^2.6.0",
    "html-rewriter-wasm": "^0.4.1",
    "htmlparser2": "^10.1.0",
    "ioredis": "^5.11.1",
    "linkedom": "^0.18.12",
    "mammoth": "^1.12.0",
    "marked": "^18.0.4",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "onnxruntime-web": "1.26.0",
    "pg": "^8.22.0",
    "piscina": "^5.2.0",
    "prom-client": "^15.1.3",
    "qrcode.react": "^4.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hotkeys-hook": "^5.3.2",
    "sanitize-html": "^2.17.5",
    "sentence-splitter": "^5.0.0",
    "sonner": "^2.0.7",
    "superjson": "^2.2.6",
    "trpc-to-openapi": "^3.2.0",
    "tsx": "^4.22.4",
    "undici": "7.28.0",
    "yaml": "^2.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "dotenv-cli": "^11.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.2.6",
    "fake-indexeddb": "^6.2.5",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "knip": "^5.83.1",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "overrides": {
      "trpc-to-openapi>h3": "^1.15.9",
      "serialize-javascript": "^7.0.5",
      "@modelcontextprotocol/sdk>hono": "^4.12.21",
      "express-rate-limit>ip-address": "^10.1.1",
      "@discordjs/ws>ws": "^8.20.1",
      "knip>smol-toml": "^1.6.1",
      "qs": "^6.15.2",
      "postcss": "^8.5.10",
      "fast-xml-parser": "^5.8.0"
    }
  },
  "packageManager": "pnpm@10.26.2+sha512.0e308ff2005fc7410366f154f625f6631ab2b16b1d2e70238444dd6ae9d630a8482d92a451144debc492416896ed16f7b114a86ec68b8404b2443869e68ffda6"
}
